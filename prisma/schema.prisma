generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Drop {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  tagline     String?
  description String?
  heroVideo   String?
  heroImage   String?
  lookbook    Json?
  status      String    @default("upcoming") // upcoming | live | sold_out | archived
  accessType  String    @default("public")   // public | password | members_only
  password    String?
  startsAt    DateTime?
  endsAt      DateTime?
  featured    Boolean   @default(false)
  products    Product[]
  notifies    NotifySignup[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  description String
  priceCents  Int
  composition String?
  fit         String?
  images      String[]
  dropId      String
  drop        Drop      @relation(fields: [dropId], references: [id], onDelete: Cascade)
  variants    Variant[]
  position    Int       @default(0)
  createdAt   DateTime  @default(now())
}

model Variant {
  id         String      @id @default(cuid())
  productId  String
  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  size       String
  stock      Int         @default(0)
  reserved   Int         @default(0)
  orderItems OrderItem[]
  @@unique([productId, size])
}

model Order {
  id             String      @id @default(cuid())
  orderNumber    String      @unique
  email          String
  phone          String
  shippingName   String
  shippingAddr   Json
  subtotalCents  Int
  shippingCents  Int
  totalCents     Int
  status         String      @default("pending") // pending | paid | shipped | delivered | cancelled
  stripeId       String?
  trackingNumber String?
  items          OrderItem[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model OrderItem {
  id         String  @id @default(cuid())
  orderId    String
  order      Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variantId  String
  variant    Variant @relation(fields: [variantId], references: [id])
  qty        Int
  priceCents Int
  nameSnap   String
  sizeSnap   String
}

model NotifySignup {
  id        String   @id @default(cuid())
  email     String
  dropId    String?
  drop      Drop?    @relation(fields: [dropId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  @@unique([email, dropId])
}
